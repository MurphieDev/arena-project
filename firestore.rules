rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isTipster() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tipster';
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone can read user profiles
      allow read: if isAuth();
      // Only the user can create their own profile
      allow create: if isOwner(userId);
      // Only the user or admin can update
      allow update: if isOwner(userId) || isAdmin();
      // Only admin can delete
      allow delete: if isAdmin();

      // Followers subcollection
      match /followers/{followerId} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
      // Following subcollection
      match /following/{followingId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
      // Bookmarks — only owner can read/write
      match /bookmarks/{postId} {
        allow read, write: if isOwner(userId);
      }
      // Reposts — only owner can read/write
      match /reposts/{postId} {
        allow read, write: if isOwner(userId);
      }
      // Likes — only owner can read/write
      match /likes/{postId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Posts ─────────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Anyone authenticated can read
      allow read: if isAuth();
      // Any authenticated user can create a post
      allow create: if isAuth();
      // Only post owner or admin can update/delete
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      // Post likes subcollection
      match /likes/{userId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
      // Post reposts subcollection
      match /reposts/{userId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
    }

    // ── Channels ─────────────────────────────────────────────────────────
    match /channels/{channelId} {
      // Anyone authenticated can read channels
      allow read: if isAuth();
      // Only tipsters can create channels
      allow create: if isTipster();
      // Only channel owner or admin can update
      allow update: if isAuth() && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();

      // Tips in channels
      match /tips/{tipId} {
        // Paid channel tips — only members or owner can read
        allow read: if isAuth() && (
          get(/databases/$(database)/documents/channels/$(channelId)).data.type == 'free' ||
          get(/databases/$(database)/documents/channels/$(channelId)).data.ownerId == request.auth.uid ||
          exists(/databases/$(database)/documents/channels/$(channelId)/members/$(request.auth.uid))
        );
        // Only tipster owner can create tips
        allow create: if isAuth() &&
          get(/databases/$(database)/documents/channels/$(channelId)).data.ownerId == request.auth.uid;
        // Only owner or admin can update (for tip verification)
        allow update: if isAuth() && (
          get(/databases/$(database)/documents/channels/$(channelId)).data.ownerId == request.auth.uid ||
          isAdmin()
        );
        allow delete: if isAdmin();
      }

      // Channel members (subscribers)
      match /members/{memberId} {
        allow read: if isAuth();
        // Members can join/leave themselves
        allow write: if isOwner(memberId) || isAdmin();
      }

      // Channel messages
      match /messages/{messageId} {
        allow read: if isAuth() && (
          get(/databases/$(database)/documents/channels/$(channelId)).data.type == 'free' ||
          exists(/databases/$(database)/documents/channels/$(channelId)/members/$(request.auth.uid))
        );
        allow create: if isAuth();
        allow update, delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // ── Notifications ─────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Only the recipient can read their notifications
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // Any authenticated user can create notifications (for sending to others)
      allow create: if isAuth();
      // Only recipient can update (mark as read) or admin
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Chats (DMs) ───────────────────────────────────────────────────────
    match /chats/{chatId} {
      // Only participants can read the chat
      allow read: if isAuth() &&
        request.auth.uid in resource.data.participants;
      // Any authenticated user can create a chat
      allow create: if isAuth() &&
        request.auth.uid in request.resource.data.participants;
      // Only participants can update (e.g. last message)
      allow update: if isAuth() &&
        request.auth.uid in resource.data.participants;

      // Chat messages
      match /messages/{messageId} {
        allow read: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Only sender can update or delete their own messages
        allow update, delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // ── Transactions ──────────────────────────────────────────────────────
    match /transactions/{txId} {
      // Users can only read their own transactions
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // Only server-side (admin) can create transactions
      allow create: if isAuth();
      // Only admin can update transaction status
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Withdrawal Requests ───────────────────────────────────────────────
    match /withdrawalRequests/{reqId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Communities ───────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );

      match /members/{memberId} {
        allow read: if isAuth();
        allow write: if isOwner(memberId) || isAdmin();
      }

      match /posts/{postId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if isAuth() && (
          resource.data.userId == request.auth.uid || isAdmin()
        );
      }

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // ── Platform wallet ───────────────────────────────────────────────────
    match /platform/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
